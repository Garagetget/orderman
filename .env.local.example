# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real credentials.

# Supabase project credentials.
# Find them in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# NOTE: Only the anon (public) key belongs here. It is safe for the browser
# because Row Level Security protects the data. NEVER put the service_role
# key in a NEXT_PUBLIC_* variable — it bypasses RLS.

# Service-role key — secret ฝั่ง server เท่านั้น (ใช้กับ admin client ใน
# user-management actions). ⚠️ bypass RLS → ห้าม commit ค่าจริง และห้ามขึ้น
# NEXT_PUBLIC_* เด็ดขาด. local ใส่ค่าของ project dev; Vercel Production ใส่ค่า
# ของ orderman-prod (key dev/prod คนละตัว — อย่าสลับ).
SUPABASE_SERVICE_ROLE_KEY=
