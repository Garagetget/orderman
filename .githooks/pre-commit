#!/bin/sh
# Fast pre-commit gate: lint + unit tests must pass before a commit lands.
# Activated by the package.json "prepare" script (sets core.hooksPath to
# .githooks on npm install). Bypass in a real pinch with `git commit --no-verify`.
set -e

echo "pre-commit ▶ npm run lint"
npm run lint

echo "pre-commit ▶ npm test"
npm test
